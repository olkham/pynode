{
  "nodes": [
    {
      "id": "inject_1",
      "type": "InjectNode",
      "name": "Every 2s",
      "config": {
        "props": [
          {
            "property": "payload",
            "value": "{\"hello\": \"pynode\", \"count\": 1}",
            "valueType": "json"
          }
        ],
        "topic": "socket/demo",
        "once": "",
        "repeat": "2"
      },
      "x": 80,
      "y": 80
    },
    {
      "id": "udp_out_1",
      "type": "UdpOutNode",
      "name": "UDP Out (7401)",
      "config": {
        "host": "127.0.0.1",
        "port": 7401,
        "chunk_size": "60000",
        "encode_images": true,
        "include_msg_props": false
      },
      "x": 340,
      "y": 80
    },
    {
      "id": "udp_in_1",
      "type": "UdpInNode",
      "name": "UDP In (7402)",
      "config": {
        "bind_host": "0.0.0.0",
        "port": 7402,
        "reassembly_timeout": 2.0
      },
      "x": 80,
      "y": 260
    },
    {
      "id": "debug_1",
      "type": "DebugNode",
      "name": "Debug",
      "config": {
        "complete": "msg",
        "console": false,
        "drop_messages": true
